# ─── Band agent credentials (register each at https://app.band.ai) ───
SCAN_AGENT_ID=
SCAN_AGENT_API_KEY=
SECURITY_AGENT_ID=
SECURITY_AGENT_API_KEY=
RISK_AGENT_ID=
RISK_AGENT_API_KEY=
DEPLOY_AGENT_ID=
DEPLOY_AGENT_API_KEY=
REPORT_AGENT_ID=
REPORT_AGENT_API_KEY=

# Service identity the webhook uses to create the room / post the opening @ScanAgent message.
# (Spike C: this may be a dedicated Band REST token or a 6th "Webhook" agent identity.)
# REST + WebSocket base URLs match the band-sdk Agent defaults.
BAND_SERVICE_API_KEY=
BAND_REST_URL=https://app.band.ai
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# ─── LLM providers (OpenAI-compatible) ───
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1

# ─── GitHub ───
# PAT (or App token) needs: contents:read, pull_requests:write, actions:write
GITHUB_TOKEN=
# Repo DeployGuard WATCHES (owner/name) — where demo PRs are opened
TARGET_REPO=your-org/deployguard-target
# Workflow file (in TARGET_REPO) that DeployAgent fires via workflow_dispatch
DEPLOY_WORKFLOW_FILE=deploy.yml
# Secret shared with the GitHub webhook for HMAC-SHA256 verification
GITHUB_WEBHOOK_SECRET=

# ─── Webhook server ───
PORT=8000

# Engineer's Band handle to @mention on BLOCK / ESCALATE (human-in-the-loop)
ENGINEER_HANDLE=@dan
